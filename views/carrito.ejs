<div class="section-container">
  <h1 class="cart-title">TU CARRITO</h1>

  <div class="cart-layout">
    <!-- Cart Items -->
    <div class="cart-items" id="cart-items-container">
      <!-- Los items se renderizan dinámicamente con JavaScript -->
    </div>

    <!-- Cart Summary -->
    <div class="cart-summary" id="cart-summary" style="display: none;">
      <h3 class="cart-summary-title">Resumen del Pedido</h3>
      <div class="cart-summary-row">
        <span>Subtotal</span>
        <span id="cart-subtotal">$ 0</span>
      </div>
      <div class="cart-summary-row">
        <span>Envío</span>
        <span id="cart-shipping">$ 0</span>
      </div>
      <div class="cart-summary-total">
        <span>Total</span>
        <span id="cart-total">$ 0</span>
      </div>
      <a href="/checkout" class="btn-checkout">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
          <line x1="1" y1="10" x2="23" y2="10"></line>
        </svg>
        PROCEDER AL PAGO
      </a>
    </div>
  </div>

  <!-- Empty State -->
  <div class="empty-cart" id="empty-cart" style="display: none;">
    <div class="empty-cart-icon">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
    </div>
    <h3 class="empty-cart-title">Tu carrito está vacío</h3>
    <p class="empty-cart-text">Explora nuestros productos y encuentra lo que necesitas.</p>
    <a href="/" class="btn-primary" style="margin-top: 8px;">VER PRODUCTOS</a>
  </div>
</div>

<script>
// Datos de productos del servidor
const allProducts = <%- JSON.stringify(products) %>;

function renderCart() {
  const cart = CartManager.getCart();
  const container = document.getElementById('cart-items-container');
  const summary = document.getElementById('cart-summary');
  const emptyState = document.getElementById('empty-cart');

  if (cart.length === 0) {
    container.style.display = 'none';
    summary.style.display = 'none';
    emptyState.style.display = 'block';
    return;
  }

  container.style.display = 'block';
  summary.style.display = 'block';
  emptyState.style.display = 'none';

  let subtotal = 0;
  let html = '';

  cart.forEach(item => {
    const product = allProducts.find(p => p.id === item.productId);
    if (!product) return;
    const itemSubtotal = product.price * item.quantity;
    subtotal += itemSubtotal;

    html += `
      <div class="cart-item" data-product-id="${product.id}">
        <img src="${product.image}" alt="${product.name}" class="cart-item-image">
        <div>
          <div class="cart-item-name">${product.name}</div>
          <div class="cart-item-category">${product.category}</div>
        </div>
        <div class="cart-item-price">$ ${product.price.toLocaleString('es-CO')}</div>
        <div class="cart-item-quantity">
          <button class="cart-item-qty-btn" onclick="updateCartQty(${product.id}, -1)">−</button>
          <span class="cart-item-qty-value">${item.quantity}</span>
          <button class="cart-item-qty-btn" onclick="updateCartQty(${product.id}, 1)">+</button>
        </div>
        <button class="cart-item-remove" onclick="removeFromCart(${product.id})">Eliminar</button>
      </div>
    `;
  });

  container.innerHTML = html;

  // Calcular totales
  const shipping = subtotal > 150000 ? 0 : 15000;
  const total = subtotal + shipping;

  document.getElementById('cart-subtotal').textContent = '$ ' + subtotal.toLocaleString('es-CO');
  document.getElementById('cart-shipping').textContent = shipping === 0 ? 'GRATIS' : '$ ' + shipping.toLocaleString('es-CO');
  document.getElementById('cart-total').textContent = '$ ' + total.toLocaleString('es-CO');
}

function updateCartQty(productId, delta) {
  const cart = CartManager.getCart();
  const item = cart.find(i => i.productId === productId);
  if (item) {
    const newQty = item.quantity + delta;
    CartManager.updateQuantity(productId, newQty);
    renderCart();
  }
}

function removeFromCart(productId) {
  CartManager.removeItem(productId);
  renderCart();
}

// Renderizar al cargar
document.addEventListener('DOMContentLoaded', renderCart);
</script>
