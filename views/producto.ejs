<div class="section-container">
  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <a href="/">Inicio</a> 
    <span> / </span>
    <a href="/categoria/<%= product.category %>"><%= categoryName %></a>
    <span> / </span>
    <span><%= product.name %></span>
  </nav>

  <!-- Product Detail -->
  <div class="product-detail">
    <div class="product-detail-image">
      <img src="<%= product.image %>" alt="<%= product.name %>">
    </div>
    <div class="product-detail-info">
      <% if (product.discount > 0) { %>
        <span class="product-detail-discount">-<%= product.discount %>% DE DESCUENTO</span>
      <% } %>
      <h1 class="product-detail-name"><%= product.name %></h1>
      <div class="product-detail-price"><%= formatPrice(product.price) %></div>
      <% if (product.oldPrice) { %>
        <span class="product-detail-old-price"><%= formatPrice(product.oldPrice) %></span>
      <% } %>
      <p class="product-detail-description"><%= product.description %></p>

      <div class="quantity-selector">
        <span style="font-size: 14px; font-weight: 500; color: #555;">Cantidad:</span>
        <button class="quantity-btn qty-minus">−</button>
        <input type="number" class="quantity-input" value="1" min="1" max="99">
        <button class="quantity-btn qty-plus">+</button>
      </div>

      <div class="detail-actions">
        <button class="btn-add-cart-large" data-product-id="<%= product.id %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          AÑADIR AL CARRITO
        </button>
        <button class="btn-buy-now">COMPRAR AHORA</button>
      </div>
    </div>
  </div>

  <!-- Productos Relacionados -->
  <% if (relatedProducts && relatedProducts.length > 0) { %>
    <div style="margin-top: 60px;">
      <div class="section-header">
        <h2 class="section-title">PRODUCTOS RELACIONADOS</h2>
        <div class="section-line"></div>
      </div>
      <div class="product-grid-4">
        <% relatedProducts.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>
