<section class="admin-section">
  <div class="admin-container">

    <div class="admin-header">
      <a href="/products" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver al listado
      </a>
      <h1 class="admin-title">Editar Producto</h1>
      <p class="admin-subtitle">Modificá los datos de <strong><%= product.name %></strong>.</p>
    </div>

    <% if (typeof errorMsg !== 'undefined') { %><div class="alert alert-error"><%= errorMsg %></div><% } %>

    <form class="product-form" action="/products/<%= product.id %>?_method=PUT" method="POST">
      <div class="form-grid">

        <div class="form-group form-group--full">
          <label class="form-label" for="name">Nombre del producto <span class="required">*</span></label>
          <input type="text" id="name" name="name" class="form-input" value="<%= product.name %>" required>
        </div>

        <div class="form-group form-group--full">
          <label class="form-label" for="description">Descripción <span class="required">*</span></label>
          <textarea id="description" name="description" class="form-input form-textarea" rows="4" required><%= product.description %></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="price">Precio (COP) <span class="required">*</span></label>
          <input type="number" id="price" name="price" class="form-input" min="0" value="<%= product.price %>" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="oldPrice">Precio anterior (COP)</label>
          <input type="number" id="oldPrice" name="oldPrice" class="form-input" placeholder="Opcional" min="0" value="<%= product.oldPrice || '' %>">
        </div>

        <div class="form-group">
          <label class="form-label" for="discount">Descuento (%)</label>
          <input type="number" id="discount" name="discount" class="form-input" min="0" max="100" value="<%= product.discount || 0 %>">
        </div>

        <div class="form-group">
          <label class="form-label" for="category">Categoría <span class="required">*</span></label>
          <select id="category" name="category" class="form-input form-select" required>
            <option value="">— Seleccionar categoría —</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= product.category === cat.id ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group form-group--full">
          <label class="form-label" for="image">URL de imagen <span class="required">*</span></label>
          <div class="image-preview-wrap">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="image-preview" id="imgPreview">
          </div>
          <input type="text" id="image" name="image" class="form-input" value="<%= product.image %>" required oninput="document.getElementById('imgPreview').src = this.value">
          <p class="form-hint">La vista previa se actualiza al escribir.</p>
        </div>

        <div class="form-group form-group--full">
          <label class="form-label checkbox-label">
            <input type="checkbox" name="featured" value="true" class="form-checkbox" <%= product.featured ? 'checked' : '' %>>
            Mostrar como producto destacado en la home
          </label>
        </div>

      </div>
      <div class="form-actions">
        <a href="/products" class="btn-secondary">Cancelar</a>
        <button type="submit" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
          Guardar cambios
        </button>
      </div>
    </form>

    <!-- Zona de peligro: eliminar -->
    <div class="danger-zone">
      <h3 class="danger-title">Zona de peligro</h3>
      <p class="danger-desc">Eliminás el producto de forma permanente. Esta acción no se puede deshacer.</p>
      <form action="/products/<%= product.id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Seguro que querés eliminar «<%= product.name %>»? Esta acción no se puede deshacer.')">
        <button type="submit" class="btn-danger">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14H6L5 6"></path><path d="M10 11v6M14 11v6"></path><path d="M9 6V4h6v2"></path></svg>
          Eliminar este producto
        </button>
      </form>
    </div>

  </div>
</section>
