<section class="admin-section">
  <div class="admin-container">

    <div class="admin-header">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver al inicio
      </a>
      <h1 class="admin-title">Nuevo Producto</h1>
      <p class="admin-subtitle">Completá el formulario para agregar un producto al catálogo.</p>
    </div>

    <% if (typeof successMsg !== 'undefined') { %>
      <div class="alert alert-success"><%= successMsg %></div>
    <% } %>
    <% if (typeof errorMsg !== 'undefined') { %>
      <div class="alert alert-error"><%= errorMsg %></div>
    <% } %>

    <form class="product-form" action="/admin/productos/crear" method="POST">

      <div class="form-grid">

        <!-- Nombre -->
        <div class="form-group form-group--full">
          <label class="form-label" for="name">Nombre del producto <span class="required">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            class="form-input"
            placeholder="Ej: iPhone 15 128 GB"
            value="<%= typeof formData !== 'undefined' ? formData.name : '' %>"
            required
          >
        </div>

        <!-- Descripción -->
        <div class="form-group form-group--full">
          <label class="form-label" for="description">Descripción <span class="required">*</span></label>
          <textarea
            id="description"
            name="description"
            class="form-input form-textarea"
            placeholder="Descripción detallada del producto..."
            rows="4"
            required
          ><%= typeof formData !== 'undefined' ? formData.description : '' %></textarea>
        </div>

        <!-- Precio -->
        <div class="form-group">
          <label class="form-label" for="price">Precio (COP) <span class="required">*</span></label>
          <input
            type="number"
            id="price"
            name="price"
            class="form-input"
            placeholder="Ej: 2999000"
            min="0"
            value="<%= typeof formData !== 'undefined' ? formData.price : '' %>"
            required
          >
        </div>

        <!-- Precio anterior -->
        <div class="form-group">
          <label class="form-label" for="oldPrice">Precio anterior (COP)</label>
          <input
            type="number"
            id="oldPrice"
            name="oldPrice"
            class="form-input"
            placeholder="Ej: 3499000 (opcional)"
            min="0"
            value="<%= typeof formData !== 'undefined' ? formData.oldPrice : '' %>"
          >
        </div>

        <!-- Descuento -->
        <div class="form-group">
          <label class="form-label" for="discount">Descuento (%)</label>
          <input
            type="number"
            id="discount"
            name="discount"
            class="form-input"
            placeholder="Ej: 15"
            min="0"
            max="100"
            value="<%= typeof formData !== 'undefined' ? formData.discount : '0' %>"
          >
        </div>

        <!-- Categoría -->
        <div class="form-group">
          <label class="form-label" for="category">Categoría <span class="required">*</span></label>
          <select id="category" name="category" class="form-input form-select" required>
            <option value="">— Seleccionar categoría —</option>
            <% categories.forEach(cat => { %>
              <option
                value="<%= cat.id %>"
                <%= (typeof formData !== 'undefined' && formData.category === cat.id) ? 'selected' : '' %>
              >
                <%= cat.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Imagen -->
        <div class="form-group form-group--full">
          <label class="form-label" for="image">URL de imagen <span class="required">*</span></label>
          <input
            type="text"
            id="image"
            name="image"
            class="form-input"
            placeholder="Ej: /images/product-iphone-15.jpg"
            value="<%= typeof formData !== 'undefined' ? formData.image : '' %>"
            required
          >
          <p class="form-hint">Ingresá la ruta relativa dentro de <code>/public/images/</code> o una URL completa.</p>
        </div>

        <!-- Destacado -->
        <div class="form-group form-group--full">
          <label class="form-label checkbox-label">
            <input
              type="checkbox"
              name="featured"
              value="true"
              class="form-checkbox"
              <%= (typeof formData !== 'undefined' && formData.featured) ? 'checked' : '' %>
            >
            Mostrar como producto destacado en la home
          </label>
        </div>

      </div><!-- /form-grid -->

      <div class="form-actions">
        <a href="/" class="btn-secondary">Cancelar</a>
        <button type="submit" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Crear producto
        </button>
      </div>

    </form>
  </div>
</section>
