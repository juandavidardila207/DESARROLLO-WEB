<section class="admin-section">
  <div class="admin-container admin-container--wide">

    <div class="admin-header admin-header--row">
      <div>
        <h1 class="admin-title">Administrar Productos</h1>
        <p class="admin-subtitle"><%= products.length %> productos en el catálogo</p>
      </div>
      <a href="/products/create" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nuevo producto
      </a>
    </div>

    <% if (typeof successMsg !== 'undefined') { %>
      <div class="alert alert-success"><%= successMsg %></div>
    <% } %>

    <div class="products-table-wrap">
      <table class="products-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Imagen</th>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Precio</th>
            <th>Descuento</th>
            <th>Destacado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(product => { %>
            <tr>
              <td class="td-id">#<%= product.id %></td>
              <td class="td-img">
                <img src="<%= product.image %>" alt="<%= product.name %>" class="table-product-img">
              </td>
              <td class="td-name">
                <a href="/products/<%= product.id %>" class="product-name-link"><%= product.name %></a>
                <span class="product-slug">/<%= product.slug %></span>
              </td>
              <td>
                <span class="badge badge--category"><%= product.category %></span>
              </td>
              <td class="td-price"><%= formatPrice(product.price) %></td>
              <td>
                <% if (product.discount > 0) { %>
                  <span class="badge badge--discount">-<%= product.discount %>%</span>
                <% } else { %>
                  <span class="td-muted">—</span>
                <% } %>
              </td>
              <td>
                <% if (product.featured) { %>
                  <span class="badge badge--featured">✓ Sí</span>
                <% } else { %>
                  <span class="td-muted">No</span>
                <% } %>
              </td>
              <td class="td-actions">
                <a href="/products/<%= product.id %>/edit" class="action-btn action-btn--edit" title="Editar">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                  Editar
                </a>

                <form action="/products/<%= product.id %>?_method=DELETE" method="POST" class="delete-form" onsubmit="return confirm('¿Seguro que querés eliminar «<%= product.name %>»? Esta acción no se puede deshacer.')">
                  <button type="submit" class="action-btn action-btn--delete" title="Eliminar">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6l-1 14H6L5 6"></path>
                      <path d="M10 11v6M14 11v6"></path>
                      <path d="M9 6V4h6v2"></path>
                    </svg>
                    Eliminar
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</section>
