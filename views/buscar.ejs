<div class="section-container">
  <div class="search-header">
    <% if (query) { %>
      <h1 class="search-title">Resultados para "<span class="search-query"><%= query %></span>"</h1>
      <p class="search-count"><%= results.length %> producto<%= results.length !== 1 ? 's' : '' %> encontrado<%= results.length !== 1 ? 's' : '' %></p>
    <% } else { %>
      <h1 class="search-title">Buscar Productos</h1>
      <p class="search-count">Escribe un término de búsqueda para encontrar productos.</p>
    <% } %>
  </div>

  <% if (query) { %>
    <% if (results.length > 0) { %>
      <div class="product-grid-4" style="padding-bottom: 48px;">
        <% results.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="no-results">
        <div class="no-results-title">No encontramos resultados</div>
        <p class="no-results-text">Intenta con otra palabra o revisa la ortografía.</p>
        <a href="/" class="btn-primary" style="margin-top: 16px;">VER TODOS LOS PRODUCTOS</a>
      </div>
    <% } %>
  <% } %>
</div>
